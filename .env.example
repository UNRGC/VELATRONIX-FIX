# ---- Base de datos ----
# Dentro de docker-compose el host es "postgres". Fuera de Docker usa localhost.
DATABASE_URL="postgresql://reparaciones:reparaciones@postgres:5432/reparaciones?schema=public"
POSTGRES_USER=reparaciones
POSTGRES_PASSWORD=reparaciones
POSTGRES_DB=reparaciones

# ---- Auth ----
JWT_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"
JWT_EXPIRES_IN="12h"

# ---- Usuario administrador inicial (seed) ----
ADMIN_NAME="Administrador"
ADMIN_EMAIL="admin@reparaciones.local"
ADMIN_PASSWORD="Admin1234!"

# ---- SMTP (Mailpit en local) ----
SMTP_HOST="mailpit"
SMTP_PORT=1025
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM_NAME="Taller de Reparaciones"
SMTP_FROM_EMAIL="no-reply@reparaciones.local"
# Correo(s) que reciben avisos internos (comprobante recibido, etc). Separar por coma.
INTERNAL_NOTIFY_EMAILS="admin@reparaciones.local"

# ---- App ----
# URL pública donde el cliente consulta su reparación (para los correos).
APP_PUBLIC_URL="http://localhost:5173"
PORT=4000

# ---- Uploads ----
UPLOAD_DIR="/data/uploads"
MAX_UPLOAD_SIZE_MB=5

# ---- Frontend (build-time) ----
VITE_API_URL="http://localhost:4000"
