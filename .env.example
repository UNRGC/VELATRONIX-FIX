# =============================================================================
# Variables de entorno de Velatronix. Copia este archivo a `.env` y ajústalo.
#   cp .env.example .env
# En Dokploy, pega estas variables en la sección Environment del proyecto.
# Las marcadas como REQUERIDO no tienen valor por defecto seguro.
# =============================================================================

# ---- Base de datos (PostgreSQL) ----
POSTGRES_USER=velatronix
POSTGRES_PASSWORD=cambia-esta-contraseña            # REQUERIDO
POSTGRES_DB=velatronix
# Cadena de conexión que usa Prisma. El host "postgres" es el nombre del servicio
# en docker-compose; usa el mismo usuario/contraseña/BD de arriba.
DATABASE_URL="postgresql://velatronix:cambia-esta-contraseña@postgres:5432/velatronix?schema=public"

# ---- Autenticación ----
JWT_SECRET=genera-un-secreto-largo-aleatorio        # REQUERIDO (p.ej. `openssl rand -hex 32`)
JWT_EXPIRES_IN=12h

# ---- Usuario administrador inicial (se crea al primer arranque) ----
ADMIN_NAME=Administrador
ADMIN_EMAIL=admin@tu-dominio.com                    # REQUERIDO
ADMIN_PASSWORD=define-una-clave-larga-unica         # REQUERIDO

# ---- SMTP (envío de correos) ----
# En desarrollo con el override, apunta a Mailpit (host "mailpit", puerto 1025).
# En producción usa tu proveedor real (SendGrid, Amazon SES, Zoho, etc.).
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=Velatronix Reparaciones
SMTP_FROM_EMAIL=no-reply@velatronix.local
# Correo(s) que reciben avisos internos (nuevo comprobante, etc). Separa por coma.
INTERNAL_NOTIFY_EMAILS=admin@velatronix.local

# ---- App ----
# URL pública desde donde el cliente consulta (se usa en los enlaces de los correos).
# En producción: https://tu-dominio.com
APP_PUBLIC_URL=http://localhost:5173
# Orígenes permitidos para CORS. Separa por coma si usas más de uno.
CORS_ORIGINS=http://localhost:5173

# Tamaño máximo de comprobante en MB (el nginx del frontend admite hasta 12 MB de body).
MAX_UPLOAD_SIZE_MB=5

# ---- Publicación del frontend (solo compose base, sin Dokploy) ----
# Puerto del host que se mapea al nginx del frontend. En Dokploy no hace falta:
# su proxy (Traefik) enruta al puerto 80 del contenedor por el dominio asignado.
FRONTEND_PORT=8080
